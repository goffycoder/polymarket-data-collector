# Canonical local runtime env file.
# Copy this to .env.runtime and fill in the values you actually want on your machine.

# Database
POLYMARKET_DB_BACKEND=sqlite
POLYMARKET_SQLITE_PATH=database/polymarket_state.db
# POLYMARKET_DB_BACKEND=postgres
# POLYMARKET_DATABASE_URL=postgresql+psycopg://USER:PASS@localhost:5432/polymarket

# Phase 3 live detector
POLYMARKET_ENABLE_PHASE3_DETECTOR=true
POLYMARKET_ALLOW_COLLECTOR_ONLY_RUNTIME=false
POLYMARKET_PHASE3_STATE_BACKEND=sqlite
POLYMARKET_PHASE3_STATE_SQLITE_PATH=database/phase3_state.db
# POLYMARKET_PHASE3_STATE_BACKEND=redis
# POLYMARKET_REDIS_URL=redis://localhost:6379/0
POLYMARKET_PHASE3_POLL_SECONDS=5
POLYMARKET_PHASE3_CHECKPOINT_INTERVAL=25
POLYMARKET_PHASE3_SOURCE_SYSTEMS=clob_ws_market,data_api_trades,data_api_trades_backfill,clob_prices,clob_books

# Phase 4 live runtime
# Canonical default local runtime profile is alert_live.
POLYMARKET_ENABLE_PHASE4_RUNTIME=true
POLYMARKET_PHASE4_RUNTIME_POLL_SECONDS=60
POLYMARKET_PHASE4_RUNTIME_PENDING_LIMIT=10
POLYMARKET_ENABLE_PHASE4_TELEGRAM=false
POLYMARKET_ENABLE_PHASE4_DISCORD=false
# Keep delivery secrets out of this file.
# Put Telegram / Discord credentials in shell env vars, an OS keychain-backed loader,
# or a repo-ignored .env.runtime.secrets file.

# Phase 6 live runtime
# Enable only after a shadow model has been registered and activated.
POLYMARKET_ENABLE_PHASE6_SHADOW_MODE=false
POLYMARKET_ENABLE_PHASE6_LIVE_RUNTIME=false
POLYMARKET_PHASE6_LIVE_LOOKBACK_MINUTES=30
POLYMARKET_PHASE6_LIVE_POLL_SECONDS=30

# Phase 11 runtime storage safety
POLYMARKET_PHASE11_RUNTIME_STORAGE_CHECK_SECONDS=300
POLYMARKET_PHASE11_RUNTIME_MIN_FREE_GB=5
POLYMARKET_PHASE11_RUNTIME_MIN_FREE_PERCENT=10
POLYMARKET_PHASE11_RUNTIME_WARN_MANAGED_GB=25
POLYMARKET_PHASE11_LOG_RETENTION_DAYS=14
POLYMARKET_PHASE11_MANUAL_REPLAY_RETENTION_DAYS=30
POLYMARKET_PHASE11_OPERATOR_REPORT_RETENTION_DAYS=30
