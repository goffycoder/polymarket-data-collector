# Repo-ignored secret env template for the canonical runtime.
# Preferred path: OS environment variables or a local keychain-backed loader.
# Acceptable local fallback: copy this file to .env.runtime.secrets and keep it out of git.

# Optional passworded database DSN
# POLYMARKET_DATABASE_URL=postgresql+psycopg://USER:PASS@localhost:5432/polymarket

