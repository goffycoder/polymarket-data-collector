# .gitignore

# Python
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
.env

# SQLite database files
*.db
*.db-journal
*.db-wal
*.db-shm

# Local data exports / temp files
database/*.csv
database/*.csv.*
*.tmp
data/

# macOS
.DS_Store

# Logs
logs/

# Documentation (track sources; ignore build artifacts)
Documentation/build/
Documentation/*.synctex.gz
Documentation/*.aux
Documentation/*.fdb_latexmk
Documentation/*.fls
Documentation/*.log
Documentation/*.out
Documentation/**/*.aux
Documentation/**/*.fdb_latexmk
Documentation/**/*.fls
Documentation/**/*.log
Documentation/**/*.out
Documentation/**/*.synctex.gz
Documentation/**/*.toc
Documentation/phases/*.aux
Documentation/phases/*.log
Documentation/person1Phases/*.aux
Documentation/person1Phases/*.log
Documentation/person2Phases/*.aux
Documentation/person2Phases/*.log

# Deployed service (contains local absolute paths — use polymarket.plist template instead)
com.polymarket.collector.plist
